{
    "swagger": "2.0",
    "info": {
        "description": "System zarządzania projektami remontowymi",
        "title": "Renovation API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8081",
    "basePath": "/api",
    "paths": {
        "/api/admin/renovations": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Tworzy nowy remont i przypisuje go do istniejącego klienta. Wymaga roli admin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "remonty"
                ],
                "summary": "Tworzy nowy projekt remontowy",
                "parameters": [
                    {
                        "description": "Dane nowego remontu",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.CreateRenovationInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.Renovation"
                        }
                    }
                }
            }
        },
        "/api/admin/renovations/{id}/progress": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Rejestruje aktualizację postępu prac w projekcie. Opcjonalnie można powiązać z konkretnym zadaniem roboczym. Wymaga roli admin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "postęp prac"
                ],
                "summary": "Dodaje wpis w dzienniku prac",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Remontu",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Dane aktualizacji postępu",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.AddProgressUpdateInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.ProgressUpdate"
                        }
                    }
                }
            }
        },
        "/api/admin/renovations/{id}/tasks": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Dodaje pozycję roboczą (praca) do istniejącego projektu remontowego. Wymaga roli admin.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "remonty"
                ],
                "summary": "Dodaje usługę roboczą do kosztorysu",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Remontu",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Dane usługi roboczej",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.AddLaborTaskInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.LaborTask"
                        }
                    }
                }
            }
        },
        "/api/admin/renovations/{id}/transactions": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Dodaje wpłatę/zakup materiałów lub płatność za pracę do projektu. Wymaga roli admin. Dozwolone typy: material_deposit, material_expense, labour_payment.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transakcje"
                ],
                "summary": "Rejestruje transakcję finansową",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Remontu",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Dane transakcji",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.AddTransactionInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Transaction"
                        }
                    }
                }
            }
        },
        "/api/renovations/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zwraca pełne dane remontu wraz z klientem i listą usług roboczych. Dostęp dla admina lub przypisanego klienta.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "remonty"
                ],
                "summary": "Szczegóły remontu",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Remontu",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Renovation"
                        }
                    }
                }
            }
        },
        "/api/renovations/{id}/summary": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Agreguje koszty pracy, płatności, wpłaty na materiały i wydatki. Zwraca salda. Dostęp dla admina lub przypisanego klienta.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "remonty"
                ],
                "summary": "Zwraca podsumowanie finansowe remontu",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Remontu",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Renovation"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.AddLaborTaskInput": {
            "type": "object",
            "required": [
                "label",
                "quantity",
                "unit",
                "unit_price"
            ],
            "properties": {
                "label": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "quantity": {
                    "type": "number"
                },
                "unit": {
                    "type": "string"
                },
                "unit_price": {
                    "type": "number"
                }
            }
        },
        "handlers.AddProgressUpdateInput": {
            "type": "object",
            "required": [
                "title"
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "labor_task_id": {
                    "type": "string"
                },
                "photos": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "handlers.AddTransactionInput": {
            "type": "object",
            "required": [
                "amount",
                "type"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "note": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "handlers.CreateRenovationInput": {
            "type": "object",
            "required": [
                "client_id",
                "name"
            ],
            "properties": {
                "client_id": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "models.LaborTask": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "number"
                },
                "date": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "label": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "quantity": {
                    "type": "number"
                },
                "renovationID": {
                    "type": "string"
                },
                "status": {
                    "description": "pending, in_progress, completed",
                    "type": "string"
                },
                "unit": {
                    "type": "string"
                },
                "unitPrice": {
                    "type": "number"
                }
            }
        },
        "models.Message": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "isRead": {
                    "type": "boolean"
                },
                "receiverID": {
                    "type": "string"
                },
                "renovationID": {
                    "type": "string"
                },
                "senderID": {
                    "type": "string"
                }
            }
        },
        "models.ProgressUpdate": {
            "type": "object",
            "properties": {
                "date": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "labor_task_id": {
                    "type": "string"
                },
                "photos": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "renovation_id": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "models.Renovation": {
            "type": "object",
            "properties": {
                "client": {
                    "$ref": "#/definitions/models.User"
                },
                "clientID": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "laborTasks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.LaborTask"
                    }
                },
                "messages": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Message"
                    }
                },
                "name": {
                    "type": "string"
                },
                "progressUpdates": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.ProgressUpdate"
                    }
                },
                "status": {
                    "description": "estimation, in_progress, completed",
                    "type": "string"
                },
                "transactions": {
                    "type": "array",
                    "items": {
