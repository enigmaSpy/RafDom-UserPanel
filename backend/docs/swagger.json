                    }
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "models.Transaction": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "number"
                },
                "date": {
                    "type": "string"
                },
                "documentURL": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "renovationID": {
                    "type": "string"
                },
                "type": {
                    "description": "material_deposit, material_expense, labor_payment",
                    "type": "string"
                }
